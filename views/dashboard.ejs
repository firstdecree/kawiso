<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kawiso</title>
    <link rel="canonical" href="https://kawiso.vercel.app/">
    <meta property="og:url" content="https://kawiso.vercel.app/">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Kawiso">
    <meta property="og:title" content="Kawiso">
    <meta property="og:description"
        content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
    <meta name="twitter:description"
        content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
    <meta name="theme-color" content="#FFFFFF">
    <link rel="icon" href="/assets/img/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap"
        rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --bg-color: #000000;
            --sidebar-bg: #000000;
            --surface: #0f0f0f;
            --surface-2: #161616;
            --surface-hover: #1c1c1c;
            --border: #222222;
            --border-light: #2a2a2a;
            --text-primary: #f5f5f5;
            --text-secondary: #a3a3a3;
            --text-muted: #5a5a5a;
            --accent: #7c3aed;
            --accent-soft: rgba(124, 58, 237, 0.12);
            --accent-2: #06b6d4;
            --accent-2-soft: rgba(6, 182, 212, 0.12);
            --green: #22c55e;
            --green-soft: rgba(34, 197, 94, 0.12);
            --red: #ef4444;
            --orange: #f97316;
            --font-sans: 'Inter', system-ui, sans-serif;
            --font-display: 'Outfit', system-ui, sans-serif;
            --sidebar-width: 260px;
            --radius: 10px;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font-sans);
            display: flex;
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-light);
            border-radius: 99px;
        }

        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 1.25rem;
            flex-shrink: 0;
            overflow-y: auto;
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            padding: 0 0.5rem;
        }

        .sidebar-logo {
            width: 26px;
            height: 26px;
            object-fit: contain;
        }

        .sidebar-brand {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .site-selector {
            margin-bottom: 2rem;
            position: relative;
        }

        .site-selector-btn {
            width: 100%;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.7rem 1rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-family: var(--font-sans);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .site-selector-btn:hover {
            border-color: var(--text-secondary);
        }

        .site-selector-btn svg {
            width: 15px;
            height: 15px;
            color: var(--text-muted);
        }

        .site-dropdown {
            position: absolute;
            top: 100%;
            left: 0.75rem;
            right: 0.75rem;
            margin-top: 4px;
            background: var(--surface-2);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.5rem;
            z-index: 50;
            display: none;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        }

        .site-dropdown.open {
            display: block;
        }

        .site-dropdown-item {
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.2s;
            color: var(--text-primary);
        }

        .site-dropdown-item:hover {
            background: var(--surface-hover);
        }

        .nav-section {
            margin-bottom: 1.5rem;
        }

        .nav-section-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: 0.4rem;
            padding: 0 0.75rem;
        }

        .nav-list {
            list-style: none;
        }

        .nav-item {
            margin-bottom: 2px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.55rem 0.75rem;
            color: var(--text-secondary);
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.15s ease;
        }

        .nav-link svg {
            width: 16px;
            height: 16px;
            stroke-width: 2;
            flex-shrink: 0;
        }

        .nav-link:hover {
            background: var(--surface-hover);
            color: var(--text-primary);
        }

        .nav-link.active {
            background: var(--surface-2);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        #analytics-content {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        #analytics-content {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 58px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 2rem;
            background: var(--bg-color);
            position: sticky;
            top: 0;
            z-index: 20;
            gap: 1rem;
        }

        .topbar-title {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.1rem;
            flex: 1;
        }

        .topbar-controls {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .topbar-range {
            display: flex;
            gap: 4px;
            align-items: center;
        }

        .range-btn {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-secondary);
            font-family: var(--font-sans);
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.3rem 0.7rem;
            cursor: pointer;
            transition: all 0.15s;
            white-space: nowrap;
        }

        .range-btn:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }

        .range-btn.active {
            background: var(--surface-2);
            border-color: var(--border-light);
            color: var(--text-primary);
        }

        .custom-range-wrap {
            position: relative;
        }

        .custom-popover {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            background: var(--surface);
            border: 1px solid var(--border-light);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            display: none;
            flex-direction: column;
            gap: 0.75rem;
            z-index: 50;
            min-width: 280px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
        }

        .custom-popover.open {
            display: flex;
        }

        .custom-popover-title {
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--text-muted);
        }

        .custom-popover-row {
            display: flex;
            gap: 0.75rem;
            align-items: flex-end;
        }

        .custom-popover-field {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
        }

        .custom-popover-field label {
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-muted);
        }

        .custom-popover-field input[type="date"] {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-primary);
            font-family: var(--font-sans);
            font-size: 0.8rem;
            padding: 0.4rem 0.6rem;
            outline: none;
            transition: border-color 0.15s;
            width: 100%;
            color-scheme: dark;
        }

        .custom-popover-field input[type="date"]:focus {
            border-color: var(--accent);
        }

        .custom-apply-btn {
            background: var(--text-primary);
            color: #000;
            border: none;
            border-radius: 6px;
            font-family: var(--font-sans);
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.45rem 0.9rem;
            cursor: pointer;
            transition: opacity 0.15s;
            white-space: nowrap;
            align-self: flex-end;
        }

        .custom-apply-btn:hover {
            opacity: 0.85;
        }

        .topbar-divider {
            width: 1px;
            height: 20px;
            background: var(--border);
        }

        .profile-wrap {
            position: relative;
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.3rem 0.6rem 0.3rem 0.4rem;
            cursor: pointer;
            transition: all 0.15s;
            color: var(--text-primary);
        }

        .profile-btn:hover {
            background: var(--surface-hover);
            border-color: var(--border-light);
        }

        .profile-avatar {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            overflow: hidden;
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-username {
            font-size: 0.85rem;
            font-weight: 500;
        }

        .profile-caret {
            width: 14px;
            height: 14px;
            color: var(--text-muted);
            transition: transform 0.2s;
        }

        .profile-wrap.open .profile-caret {
            transform: rotate(180deg);
        }

        .profile-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: var(--surface);
            border: 1px solid var(--border-light);
            border-radius: 10px;
            min-width: 180px;
            padding: 0.5rem;
            z-index: 50;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
            display: none;
            flex-direction: column;
        }

        .profile-wrap.open .profile-dropdown {
            display: flex;
        }

        .profile-dropdown-header {
            padding: 0.5rem 0.75rem 0.75rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 0.4rem;
        }

        .profile-dropdown-name {
            font-size: 0.875rem;
            font-weight: 600;
        }

        .profile-dropdown-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .profile-dropdown-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.855rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            cursor: pointer;
            background: transparent;
            border: none;
            font-family: var(--font-sans);
            width: 100%;
            text-align: left;
            transition: all 0.15s;
        }

        .profile-dropdown-item svg {
            width: 15px;
            height: 15px;
            flex-shrink: 0;
        }

        .profile-dropdown-item:hover {
            background: var(--surface-hover);
            color: var(--text-primary);
        }

        .profile-dropdown-item.danger {
            color: #ef4444;
        }

        .profile-dropdown-item.danger:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        .page {
            padding: 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .stat-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s;
        }

        .stat-card:hover {
            border-color: var(--border-light);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--glow-color, transparent) 0%, transparent 60%);
            pointer-events: none;
        }

        .stat-card.accent-visits {
            --glow-color: rgba(124, 58, 237, 0.06);
        }

        .stat-card.accent-users {
            --glow-color: rgba(6, 182, 212, 0.06);
        }

        .stat-card.accent-bounce {
            --glow-color: rgba(249, 115, 22, 0.06);
        }

        .stat-card.accent-duration {
            --glow-color: rgba(34, 197, 94, 0.06);
        }

        .stat-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin-bottom: 0.6rem;
        }

        .stat-value {
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .stat-delta {
            font-size: 0.8rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .stat-delta.up {
            color: var(--green);
        }

        .stat-delta.down {
            color: var(--red);
        }

        .stat-delta svg {
            width: 13px;
            height: 13px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .card-legend {
            display: flex;
            gap: 1rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .card-body {
            padding: 1.25rem 1.5rem;
        }

        .chart-wrapper {
            position: relative;
            height: 220px;
        }

        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .three-col {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1rem;
        }

        .four-col {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .source-list {
            display: flex;
            flex-direction: column;
            gap: 0px;
        }

        .source-row {
            display: grid;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            gap: 1rem;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border);
        }

        .source-row:last-child {
            border-bottom: none;
        }

        .source-name {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .source-icon {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 0.75rem;
        }

        .source-bar-wrap {
            position: relative;
            width: 100%;
        }

        .source-bar-bg {
            height: 4px;
            background: var(--surface-2);
            border-radius: 99px;
            margin-top: 4px;
        }

        .source-bar-fill {
            height: 4px;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
            border-radius: 99px;
            transition: width 0.6s ease;
        }

        .source-count {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
            text-align: right;
            white-space: nowrap;
        }

        .source-pct {
            font-size: 0.78rem;
            color: var(--text-muted);
            text-align: right;
        }

        .pages-table {
            width: 100%;
            border-collapse: collapse;
        }

        .pages-table th {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            text-align: left;
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--border);
        }

        .pages-table th:last-child,
        .pages-table td:last-child {
            text-align: right;
        }

        .pages-table td {
            font-size: 0.855rem;
            color: var(--text-secondary);
            padding: 0.7rem 0;
            border-bottom: 1px solid var(--border);
        }

        .pages-table tr:last-child td {
            border-bottom: none;
        }

        .pages-table td:first-child {
            color: var(--text-primary);
            font-weight: 500;
            max-width: 240px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .pages-table td span.badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-up {
            background: var(--green-soft);
            color: var(--green);
        }

        .badge-down {
            background: rgba(239, 68, 68, 0.12);
            color: var(--red);
        }

        .dist-bar {
            display: flex;
            height: 8px;
            border-radius: 99px;
            overflow: hidden;
            gap: 2px;
            margin-bottom: 1rem;
        }

        .dist-segment {
            transition: width 0.6s ease;
        }

        .dist-legend {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .dist-legend-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.845rem;
        }

        .dist-legend-label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .dist-swatch {
            width: 10px;
            height: 10px;
            border-radius: 3px;
            flex-shrink: 0;
        }

        .dist-value {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 0.845rem;
        }

        .time-card {
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            text-align: center;
        }

        .time-card-icon {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .time-card-label {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            margin-bottom: 0.4rem;
        }

        .time-card-value {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
        }

        .time-card-share {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .country-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 0;
            border-bottom: 1px solid var(--border);
        }

        .country-row:last-child {
            border-bottom: none;
        }

        .country-flag {
            font-size: 1.15rem;
            flex-shrink: 0;
            line-height: 1;
        }

        .country-name {
            flex: 1;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .country-bar-wrap {
            width: 80px;
        }

        .country-bar-bg {
            height: 3px;
            background: var(--surface-2);
            border-radius: 99px;
        }

        .country-bar-fill {
            height: 3px;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
            border-radius: 99px;
        }

        .country-count {
            font-size: 0.855rem;
            font-weight: 600;
            width: 50px;
            text-align: right;
        }

        .country-pct {
            font-size: 0.78rem;
            color: var(--text-muted);
            width: 38px;
            text-align: right;
        }

        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 0.75rem;
        }

        .empty-state {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 4rem 2rem;
            text-align: center;
            gap: 1rem;
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 0.5rem;
        }

        .empty-state-title {
            font-family: var(--font-display);
            font-size: 1.35rem;
            font-weight: 600;
        }

        .empty-state-sub {
            font-size: 0.9rem;
            color: var(--text-secondary);
            max-width: 420px;
            line-height: 1.6;
        }

        .snippet-box {
            background: var(--surface-2);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-family: monospace;
            font-size: 0.8rem;
            color: var(--accent-2);
            word-break: break-all;
            max-width: 540px;
            text-align: left;
            position: relative;
        }

        .copy-btn {
            display: inline-block;
            margin-top: 0.75rem;
            background: var(--surface-2);
            border: 1px solid var(--border-light);
            border-radius: 6px;
            color: var(--text-secondary);
            font-family: var(--font-sans);
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.35rem 0.8rem;
            cursor: pointer;
            transition: all 0.15s;
        }

        .copy-btn:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-family: var(--font-display);
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            padding: 1.1rem 0;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            transition: all 0.2s;
        }

        .tab-btn:hover {
            color: var(--text-secondary);
        }

        .tab-btn.active {
            color: var(--text-primary);
            border-bottom: 2px solid var(--accent);
        }
    </style>
</head>

