    <script>
        let INITIAL_ANALYTICS = null;
        const COLORS_PALETTE = [
            '#7c3aed', '#06b6d4', '#22c55e', '#f97316',
            '#ec4899', '#eab308', '#3b82f6', '#ef4444',
            '#8b5cf6', '#14b8a6'
        ];
        Chart.defaults.color = '#737373';
        Chart.defaults.borderColor = '#1f1f1f';
        Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
        function fmt(n) {
            if (!n) return '0';
            return n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
        }
        const hourLabels = Array.from({ length: 24 }, (_, i) => {
            const h = i % 12 || 12;
            return h + (i < 12 ? 'am' : 'pm');
        });
        let visitsChart = null;
        let timeChart = null;
        function buildVisitsChart(labels, visitArr, userArr) {
            const ctx = document.getElementById('visitsChart').getContext('2d');
            const gV = ctx.createLinearGradient(0, 0, 0, 200);
            gV.addColorStop(0, 'rgba(124,58,237,0.25)');
            gV.addColorStop(1, 'rgba(124,58,237,0)');
            const gU = ctx.createLinearGradient(0, 0, 0, 200);
            gU.addColorStop(0, 'rgba(6,182,212,0.2)');
            gU.addColorStop(1, 'rgba(6,182,212,0)');
            if (visitsChart) visitsChart.destroy();
            visitsChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        { label: 'Total Visits', data: visitArr, borderColor: '#7c3aed', backgroundColor: gV, borderWidth: 2, pointRadius: 0, pointHoverRadius: 4, fill: true, tension: 0.4 },
                        { label: 'Unique Users', data: userArr, borderColor: '#06b6d4', backgroundColor: gU, borderWidth: 2, pointRadius: 0, pointHoverRadius: 4, fill: true, tension: 0.4 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { display: false }, tooltip: { backgroundColor: '#161616', borderColor: '#2a2a2a', borderWidth: 1, titleColor: '#f5f5f5', bodyColor: '#a3a3a3', padding: 10 } },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 11 } } },
                        y: { grid: { color: '#181818' }, ticks: { font: { size: 11 }, callback: v => v >= 1000 ? (v / 1000).toFixed(1) + 'k' : v } }
                    }
                }
            });
        }
        function buildTimeChart(hourly) {
            const ctx = document.getElementById('timeChart').getContext('2d');
            if (timeChart) timeChart.destroy();
            timeChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: hourLabels,
                    datasets: [{
                        label: 'Visits', data: hourly,
                        backgroundColor: hourly.map((_, i) => {
                            if (i >= 6 && i < 12) return 'rgba(234,179,8,0.7)';
                            if (i >= 12 && i < 18) return 'rgba(124,58,237,0.7)';
                            if (i >= 18 && i < 24) return 'rgba(249,115,22,0.7)';
                            return 'rgba(6,182,212,0.5)';
                        }),
                        borderRadius: 3, borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { backgroundColor: '#161616', borderColor: '#2a2a2a', borderWidth: 1, titleColor: '#f5f5f5', bodyColor: '#a3a3a3', padding: 8 } },
                    scales: { x: { grid: { display: false }, ticks: { maxTicksLimit: 12, font: { size: 10 } } }, y: { display: false } }
                }
            });
        }
        function setDelta(id, val) {
            const el = document.getElementById(id);
            if (!el) return;
            if (val === "New") {
                el.className = 'stat-delta up';
                el.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>New';
                return;
            }
            if (val > 0) {
                el.className = 'stat-delta up';
                el.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>' + val + '%';
            } else if (val < 0) {
                el.className = 'stat-delta down';
                el.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>' + Math.abs(val) + '%';
            } else {
                el.className = 'stat-delta';
                el.innerHTML = '0%';
            }
        }
        function renderStatCards(data) {
            document.getElementById('stat-visits').textContent = fmt(data.totalVisits);
            document.getElementById('stat-users').textContent = fmt(data.uniqueUsers);
            document.getElementById('stat-duration').textContent = data.avgDuration || '—';
            document.getElementById('stat-bounce').textContent = (data.bounceRate || 0) + '%';
            if (data.deltas) {
                setDelta('delta-visits', data.deltas.visitsDelta);
                setDelta('delta-users', data.deltas.usersDelta);
                setDelta('delta-bounce', data.deltas.bounceDelta);
                setDelta('delta-duration', data.deltas.durationDelta);
            } else {
                ['delta-visits', 'delta-users', 'delta-bounce', 'delta-duration'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.innerHTML = '';
                });
            }
        }
        function renderSources(sources) {
            const el = document.getElementById('traffic-sources');
            if (!sources || !sources.length) { el.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;padding:1rem 0;">No traffic sources yet.</div>'; return; }
            const max = Math.max(...sources.map(s => s.count));
            el.innerHTML = sources.map(s => `
                <div class="source-row">
                    <div class="source-name"><div class="source-icon">${s.icon}</div><span>${s.name}</span></div>
                    <div style="flex:1;min-width:60px;"><div class="source-bar-bg"><div class="source-bar-fill" style="width:${max ? (s.count / max * 100).toFixed(1) : 0}%"></div></div></div>
                    <div><div class="source-count">${fmt(s.count)}</div><div class="source-pct">${s.pct}%</div></div>
                </div>`).join('');
        }
        function renderPages(pages) {
            const tbody = document.getElementById('pages-tbody');
            if (!pages || !pages.length) { tbody.innerHTML = '<tr><td colspan="3" style="color:var(--text-muted);font-size:0.85rem;padding:1rem 0;">No page data yet.</td></tr>'; return; }
            tbody.innerHTML = pages.map(p => `
                <tr>
                    <td>${p.path}</td>
                    <td>${fmt(p.visits)}</td>
                    <td><span class="badge ${p.isUp ? 'badge-up' : 'badge-down'}">${p.trend}</span></td>
                </tr>`).join('');
        }
        function renderDist(targetId, items) {
            const el = document.getElementById(targetId);
            if (!items || !items.length) { el.innerHTML = '<div style="color:var(--text-muted);font-size:0.83rem;">No data yet.</div>'; return; }
            items = items.map((it, i) => ({ ...it, color: COLORS_PALETTE[i % COLORS_PALETTE.length] }));
            el.innerHTML = `
                <div class="dist-bar">${items.map(it => `<div class="dist-segment" style="width:${it.pct}%;background:${it.color};"></div>`).join('')}</div>
                <div class="dist-legend">${items.map(it => `
                    <div class="dist-legend-row">
                        <div class="dist-legend-label"><div class="dist-swatch" style="background:${it.color};"></div>${it.label}</div>
                        <div class="dist-value">${it.pct}%</div>
                    </div>`).join('')}
                </div>`;
        }
        function renderTime(tod, hourly) {
            const cfg = [
                { key: 'morning', icon: '🌅', label: 'Morning', range: '6am–12pm' },
                { key: 'afternoon', icon: '☀️', label: 'Afternoon', range: '12pm–6pm' },
                { key: 'evening', icon: '🌆', label: 'Evening', range: '6pm–12am' },
                { key: 'night', icon: '🌙', label: 'Night', range: '12am–6am' },
            ];
            const total = Object.values(tod).reduce((a, b) => a + b, 0) || 1;
            document.getElementById('time-cards').innerHTML = cfg.map(t => `
                <div class="time-card">
                    <div class="time-card-icon">${t.icon}</div>
                    <div class="time-card-label">${t.label}</div>
                    <div class="time-card-value">${fmt(tod[t.key] || 0)}</div>
                    <div class="time-card-share">${t.range} · ${Math.round((tod[t.key] || 0) / total * 100)}%</div>
                </div>`).join('');
            buildTimeChart(hourly || Array(24).fill(0));
        }
        function renderCountries(countries) {
            const el = document.getElementById('countries-list');
            if (!countries || !countries.length) { el.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;padding:1rem 0;">No country data yet.</div>'; return; }
            const max = Math.max(...countries.map(c => c.count));
            const total = countries.reduce((a, c) => a + c.count, 0) || 1;
            el.innerHTML = countries.map(c => `
                <div class="country-row">
                    <div class="country-flag">${c.flag || '🌐'}</div>
                    <div class="country-name">${c.name}</div>
                    <div class="country-bar-wrap"><div class="country-bar-bg"><div class="country-bar-fill" style="width:${max ? (c.count / max * 100).toFixed(0) : 0}%"></div></div></div>
                    <div class="country-count">${fmt(c.count)}</div>
                    <div class="country-pct">${(c.count / total * 100).toFixed(1)}%</div>
                </div>`).join('');
        }
        function renderTimezones(timezones) {
            const el = document.getElementById('timezones-list');
            if (!timezones || !timezones.length) { el.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;padding:1rem 0;">No timezone data yet.</div>'; return; }
            const max = Math.max(...timezones.map(t => t.count));
            const total = timezones.reduce((a, t) => a + t.count, 0) || 1;
            el.innerHTML = timezones.map(t => `
                <div class="country-row">
                    <div class="country-flag">🕒</div>
                    <div class="country-name">${t.name}</div>
                    <div class="country-bar-wrap"><div class="country-bar-bg"><div class="country-bar-fill" style="width:${max ? (t.count / max * 100).toFixed(0) : 0}%"></div></div></div>
                    <div class="country-count">${fmt(t.count)}</div>
                    <div class="country-pct">${(t.count / total * 100).toFixed(1)}%</div>
                </div>`).join('');
        }

        function renderAll(data) {
            if (!data) {
                document.getElementById('analytics-content').style.display = 'none';
                document.getElementById('empty-state').style.display = 'flex';
                return;
            }
            document.getElementById('analytics-content').style.display = '';
            document.getElementById('empty-state').style.display = 'none';
            renderStatCards(data);
            buildVisitsChart(data.chartLabels || [], data.visitArr || [], data.userArr || []);
            renderSources(data.sources);
            renderPages(data.pages);
            renderDist('browsers-card', data.browsers);
            renderDist('platforms-card', data.platforms);
            renderDist('devices-card', data.devices);
            renderDist('languages-card', data.languages);
            renderDist('screens-card', data.screens);
            renderTime(data.timeOfDay || {}, data.hourly);
            renderCountries(data.countries);
            renderTimezones(data.timezones);
        }
        fetchAndRender(); // Fetch on load to get data
        setInterval(async () => {
            fetchAndRender();
            try {
                const res = await fetch('/api/domains');
                const json = await res.json();
                if (json.ok && json.domains) {
                    const dropdown = document.getElementById('site-dropdown');
                    if (json.domains.length === 0) {
                        dropdown.innerHTML = '<div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No domains yet</div>';
                    } else {
                        dropdown.innerHTML = json.domains.map(d => `<div class="site-dropdown-item" onclick="setDomain('${d}')">${d}</div>`).join('');
                    }
                    const currentLabel = document.getElementById('site-selector-label').textContent.trim();
                    if ((currentLabel === 'No Domain Active' || (!json.domains.includes(currentLabel) && currentLabel !== "No Domain Active")) && json.domains.length > 0) {
                        setDomain(json.domains[0]);
                    }
                }
            } catch (e) { }
        }, 20 * 1000);

        async function init() {
            fetchAndRender();
            try {
                const res = await fetch('/api/domains');
                const json = await res.json();
                if (json.ok && json.domains) {
                    const dropdown = document.getElementById('site-dropdown');
                    if (json.domains.length === 0) {
                        dropdown.innerHTML = '<div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No domains yet</div>';
                    } else {
                        dropdown.innerHTML = json.domains.map(d => `<div class="site-dropdown-item" onclick="setDomain('${d}')">${d}</div>`).join('');
                    }
                    const currentLabel = document.getElementById('site-selector-label').textContent.trim();
                    if ((currentLabel === 'No Domain Active' || (!json.domains.includes(currentLabel) && currentLabel !== "No Domain Active")) && json.domains.length > 0) {
                        setDomain(json.domains[0]);
                    }
                }
            } catch (e) { }
        }

        // Core
        const customBtn = document.getElementById('btn-custom');
        const customPopover = document.getElementById('custom-popover');
        const customApply = document.getElementById('custom-apply');
        let currentFetchParams = { range: '1m', domain: '<%= activeDomain || "" %>' };
        async function fetchAndRender() {
            try {
                const res = await fetch('/api/analytics?' + new URLSearchParams(currentFetchParams));
                const json = await res.json();
                renderAll(json.data);
            } catch (e) { console.error('Analytics fetch failed', e); }
        }
        function setActiveRange(btn, rangeStr) {
            document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            customPopover.classList.remove('open');
            currentFetchParams.range = rangeStr;
            delete currentFetchParams.start;
            delete currentFetchParams.end;
            fetchAndRender();
        }
        document.getElementById('btn-7d').addEventListener('click', function () { setActiveRange(this, '7d'); });
        document.getElementById('btn-1m').addEventListener('click', function () { setActiveRange(this, '1m'); });
        document.getElementById('btn-1y').addEventListener('click', function () { setActiveRange(this, '1y'); });
        customBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
            customBtn.classList.add('active');
            customPopover.classList.toggle('open');
            document.getElementById('site-dropdown').classList.remove('open');
        });
        customApply.addEventListener('click', () => {
            const start = document.getElementById('date-start').value;
            const end = document.getElementById('date-end').value;
            if (!start || !end) return;
            customBtn.innerHTML = '';
            const icon = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            icon.setAttribute('viewBox', '0 0 24 24'); icon.setAttribute('fill', 'none');
            icon.setAttribute('stroke', 'currentColor'); icon.setAttribute('stroke-width', '2');
            icon.setAttribute('stroke-linecap', 'round'); icon.setAttribute('stroke-linejoin', 'round');
            icon.style.cssText = 'width:11px;height:11px;display:inline;margin-right:4px;vertical-align:-1px;';
            icon.innerHTML = '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>';
            customBtn.appendChild(icon);
            const fmtD = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' });
            customBtn.appendChild(document.createTextNode(`${fmtD(start)} – ${fmtD(end)}`));
            customPopover.classList.remove('open');
            currentFetchParams.range = 'custom';
            currentFetchParams.start = start;
            currentFetchParams.end = end;
            fetchAndRender();
        });
        document.getElementById('tab-countries').addEventListener('click', function() {
            this.classList.add('active');
            document.getElementById('tab-timezones').classList.remove('active');
            document.getElementById('countries-list').style.display = 'block';
            document.getElementById('timezones-list').style.display = 'none';
        });
        document.getElementById('tab-timezones').addEventListener('click', function() {
            this.classList.add('active');
            document.getElementById('tab-countries').classList.remove('active');
            document.getElementById('timezones-list').style.display = 'block';
            document.getElementById('countries-list').style.display = 'none';
        });
        document.addEventListener('click', (e) => {
            if (!customPopover.contains(e.target) && e.target !== customBtn) customPopover.classList.remove('open');
            if (!siteDropdown.contains(e.target) && e.target !== siteSelectorBtn && !siteSelectorBtn.contains(e.target)) siteDropdown.classList.remove('open');
        });
        const siteSelectorBtn = document.getElementById('site-selector-btn');
        const siteDropdown = document.getElementById('site-dropdown');
        siteSelectorBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            siteDropdown.classList.toggle('open');
            customPopover.classList.remove('open');
        });
        function setDomain(domain) {
            document.getElementById('site-selector-label').textContent = domain;
            currentFetchParams.domain = domain;
            fetchAndRender();
            siteDropdown.classList.remove('open');
        }
        const profileWrap = document.getElementById('profile-wrap');
        const profileBtn = document.getElementById('profile-btn');
        profileBtn.addEventListener('click', (e) => {
            e.stopPropagation(); profileWrap.classList.toggle('open'); customPopover.classList.remove('open'); siteDropdown.classList.remove('open');
        });
        document.addEventListener('click', (e) => { if (!profileWrap.contains(e.target)) profileWrap.classList.remove('open'); });
        document.getElementById('logout-btn').addEventListener('click', () => { window.location.href = '/api/logout'; });
        const copyBtn = document.getElementById('copy-snippet-btn');
        if (copyBtn) {
            copyBtn.addEventListener('click', () => {
                const text = `<script src="${window.location.origin}/tracker.js" data-id="<%= user.uuid %>"><\/script>`;
                navigator.clipboard.writeText(text).then(() => {
                    copyBtn.textContent = 'Copied!';
                    setTimeout(() => copyBtn.textContent = 'Copy', 2000);
                });
            });
        }

        // Init
        init()
    </script>
</body>

</html>