<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kawiso</title>
    <link rel="icon" href="/assets/img/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #000;
            --sidebar-bg: #000;
            --surface: #0f0f0f;
            --surface-2: #161616;
            --surface-hover: #1c1c1c;
            --border: #222;
            --border-light: #2a2a2a;
            --text-primary: #f5f5f5;
            --text-secondary: #a3a3a3;
            --text-muted: #5a5a5a;
            --accent: #7c3aed;
            --accent-2: #06b6d4;
            --font-sans: 'Inter', system-ui, sans-serif;
            --font-display: 'Outfit', system-ui, sans-serif;
            --sidebar-width: 260px
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            background: var(--bg);
            color: var(--text-primary);
            font-family: var(--font-sans);
            display: flex;
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased
        }

        ::-webkit-scrollbar {
            width: 6px
        }

        ::-webkit-scrollbar-track {
            background: transparent
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-light);
            border-radius: 99px
        }

        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 1.25rem;
            flex-shrink: 0;
            overflow-y: auto
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            padding: 0 0.5rem
        }

        .sidebar-logo {
            width: 26px;
            height: 26px;
            object-fit: contain
        }

        .sidebar-brand {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: -0.02em
        }

        .site-selector {
            margin-bottom: 2rem;
            position: relative
        }

        .site-selector-btn {
            width: 100%;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.7rem 1rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-family: var(--font-sans);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: border-color 0.2s
        }

        .site-selector-btn:hover {
            border-color: var(--text-secondary)
        }

        .site-selector-btn svg {
            width: 15px;
            height: 15px;
            color: var(--text-muted)
        }

        .site-dropdown {
            position: absolute;
            top: 100%;
            left: 0.75rem;
            right: 0.75rem;
            margin-top: 4px;
            background: var(--surface-2);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.5rem;
            z-index: 9999;
            display: none;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5)
        }

        .site-dropdown.open {
            display: block
        }

        .site-dropdown-item {
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.2s;
            color: var(--text-primary)
        }

        .site-dropdown-item:hover {
            background: var(--surface-hover)
        }

        .nav-section {
            margin-bottom: 1.5rem
        }

        .nav-section-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: 0.4rem;
            padding: 0 0.75rem
        }

        .nav-list {
            list-style: none
        }

        .nav-item {
            margin-bottom: 2px
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.55rem 0.75rem;
            color: var(--text-secondary);
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.15s ease
        }

        .nav-link svg {
            width: 16px;
            height: 16px;
            stroke-width: 2;
            flex-shrink: 0
        }

        .nav-link:hover {
            background: var(--surface-hover);
            color: var(--text-primary)
        }

        .nav-link.active {
            background: var(--surface-2);
            color: var(--text-primary);
            border: 1px solid var(--border)
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            overflow-y: auto
        }

        .topbar {
            height: 58px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 2rem;
            background: var(--bg);
            position: sticky;
            top: 0;
            z-index: 1000;
            gap: 1rem;
            flex-shrink: 0
        }

        .topbar-title {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.1rem;
            flex: 1
        }

        .topbar-controls {
            display: flex;
            align-items: center;
            gap: 0.75rem
        }

        .topbar-divider {
            width: 1px;
            height: 20px;
            background: var(--border)
        }

        .profile-wrap {
            position: relative
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.3rem 0.6rem 0.3rem 0.4rem;
            cursor: pointer;
            transition: all 0.15s;
            color: var(--text-primary)
        }

        .profile-btn:hover {
            background: var(--surface-hover);
            border-color: var(--border-light)
        }

        .profile-avatar {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            overflow: hidden
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .profile-username {
            font-size: 0.85rem;
            font-weight: 500
        }

        .profile-caret {
            width: 14px;
            height: 14px;
            color: var(--text-muted);
            transition: transform 0.2s
        }

        .profile-wrap.open .profile-caret {
            transform: rotate(180deg)
        }

        .profile-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: var(--surface);
            border: 1px solid var(--border-light);
            border-radius: 10px;
            min-width: 180px;
            padding: 0.5rem;
            z-index: 9999;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
            display: none;
            flex-direction: column
        }

        .profile-wrap.open .profile-dropdown {
            display: flex
        }

        .profile-dropdown-header {
            padding: 0.5rem 0.75rem 0.75rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 0.4rem
        }

        .profile-dropdown-name {
            font-size: 0.875rem;
            font-weight: 600
        }

        .profile-dropdown-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px
        }

        .profile-dropdown-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-size: 0.855rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            cursor: pointer;
            background: transparent;
            border: none;
            font-family: var(--font-sans);
            width: 100%;
            text-align: left;
            transition: all 0.15s
        }

        .profile-dropdown-item svg {
            width: 15px;
            height: 15px;
            flex-shrink: 0
        }

        .profile-dropdown-item:hover {
            background: var(--surface-hover);
            color: var(--text-primary)
        }

        .profile-dropdown-item.danger {
            color: #ef4444
        }

        .profile-dropdown-item.danger:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444
        }

        .settings-body {
            flex: 1;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            max-width: 720px;
            width: 100%
        }

        .settings-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem
        }

        .settings-card-title {
            font-family: var(--font-display);
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 1.25rem;
            color: var(--text-primary)
        }

        .profile-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem
        }

        .info-field {
            display: flex;
            flex-direction: column;
            gap: 4px
        }

        .info-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            font-weight: 600;
            color: var(--text-muted)
        }

        .info-value {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-primary);
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 0.5rem 0.75rem
        }

        .plan-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.15), rgba(6, 182, 212, 0.15));
            border: 1px solid rgba(124, 58, 237, 0.35);
            border-radius: 20px;
            padding: 0.35rem 0.85rem;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--accent);
            letter-spacing: 0.03em;
            text-transform: capitalize
        }

        .plan-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent);
            display: inline-block
        }

        .domains-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 1rem;
            min-height: 0
        }

        .domain-row {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem
        }

        .domain-row span {
            flex: 1;
            color: var(--text-primary);
            font-family: monospace;
            font-size: 0.82rem;
            word-break: break-all
        }

        .domain-btn {
            background: transparent;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            padding: 2px;
            border-radius: 4px;
            transition: color 0.15s, background 0.15s
        }

        .domain-btn:hover {
            color: var(--text-primary);
            background: var(--surface-hover)
        }

        .domain-btn.del:hover {
            color: #ef4444;
            background: rgba(239, 68, 68, 0.1)
        }

        .domain-btn svg {
            width: 14px;
            height: 14px;
            stroke-width: 2
        }

        .domain-add-row {
            display: flex;
            gap: 8px
        }

        .domain-input {
            flex: 1;
            background: var(--surface-2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: var(--font-sans);
            font-size: 0.875rem;
            padding: 0.55rem 0.85rem;
            outline: none;
            transition: border-color 0.15s
        }

        .domain-input:focus {
            border-color: var(--accent)
        }

        .domain-input::placeholder {
            color: var(--text-muted)
        }

        .domain-add-btn {
            background: var(--accent);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-family: var(--font-sans);
            font-size: 0.85rem;
            font-weight: 600;
            padding: 0 1rem;
            cursor: pointer;
            transition: opacity 0.15s;
            white-space: nowrap
        }

        .domain-add-btn:hover {
            opacity: 0.85
        }

        .empty-domains {
            color: var(--text-muted);
            font-size: 0.85rem;
            text-align: center;
            padding: 1rem 0
        }

        .domain-edit-input {
            flex: 1;
            background: var(--surface);
            border: 1px solid var(--accent);
            border-radius: 6px;
            color: var(--text-primary);
            font-family: monospace;
            font-size: 0.82rem;
            padding: 0.25rem 0.5rem;
            outline: none
        }
    </style>
</head>

<body>

    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="/assets/img/logo.png" alt="Kawiso" class="sidebar-logo"
                onerror="this.src='data:image/svg+xml;base64,'">
            <span class="sidebar-brand">Kawiso</span>
        </div>
        <div class="site-selector">
            <button class="site-selector-btn" id="site-selector-btn">
                <span id="site-selector-label">
                    <%= activeDomain || "No Domain Active" %>
                </span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                    stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            <div class="site-dropdown" id="site-dropdown">
                <% if (domains && domains.length> 0) { %>
                    <% domains.forEach(d=> { %>
                        <div class="site-dropdown-item" onclick="setDomain('<%= d %>')">
                            <%= d %>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No
                                    domains yet</div>
                                <% } %>
            </div>
        </div>
        <div class="nav-section">
            <div class="nav-section-title">Account</div>
            <ul class="nav-list">
                <li class="nav-item">
                    <a href="/account-settings" class="nav-link active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                            stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        Account Settings
                    </a>
                </li>
            </ul>
        </div>
        <div class="nav-section">
            <div class="nav-section-title">Web Analytics</div>
            <ul class="nav-list">
                <li class="nav-item">
                    <a href="/dashboard" class="nav-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                            stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="3" y1="9" x2="21" y2="9"></line>
                            <line x1="9" y1="21" x2="9" y2="9"></line>
                        </svg>
                        Main
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/map" class="nav-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                            stroke-linejoin="round">
                            <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon>
                            <line x1="9" y1="3" x2="9" y2="21"></line>
                            <line x1="15" y1="3" x2="15" y2="21"></line>
                        </svg>
                        Map
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/pages" class="nav-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                            stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                        </svg>
                        Pages
                    </a>
                </li>
            </ul>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <h1 class="topbar-title">Account Settings</h1>
            <div class="topbar-controls">
                <div class="topbar-divider"></div>
                <div class="profile-wrap" id="profile-wrap">
                    <button class="profile-btn" id="profile-btn">
                        <div class="profile-avatar">
                            <img src="/assets/img/profile.png" alt="Profile Picture">
                        </div>
                        <span class="profile-username">
                            <%= user.username.toUpperCase() %>
                        </span>
                        <svg class="profile-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </button>
                    <div class="profile-dropdown">
                        <div class="profile-dropdown-header">
                            <div class="profile-dropdown-name">
                                Plan
                            </div>
                            <div class="profile-dropdown-sub">
                                <%= userDoc.plan.replace(/^./, (c)=>c.toUpperCase()) %>
                            </div>
                        </div>
                        <a href="/account-settings" class="profile-dropdown-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="3"></circle>
                                <path
                                    d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z">
                                </path>
                            </svg>
                            Account Settings
                        </a>
                        <button class="profile-dropdown-item danger" id="logout-btn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            Logout
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <div class="settings-body">
            <div class="settings-card">
                <div class="settings-card-title">Profile</div>
                <div class="profile-info-grid">
                    <div class="info-field">
                        <div class="info-label">Username</div>
                        <div class="info-value">
                            <%= user.username.toUpperCase() %>
                        </div>
                    </div>
                    <div class="info-field">
                        <div class="info-label">Plan</div>
                        <div class="info-value"
                            style="background:transparent;border:none;padding:0;display:flex;align-items:center;">
                            <span class="plan-badge"><span class="plan-dot"></span>
                                <%= userDoc.plan || 'Analyst' %>
                            </span>
                        </div>
                    </div>
                    <div class="info-field" style="grid-column:1/-1;">
                        <div class="info-label">UUID</div>
                        <div class="info-value"
                            style="font-family:monospace;font-size:0.8rem;color:var(--text-secondary)">
                            <%= user.uuid %>
                        </div>
                    </div>
                    <div class="info-field" style="grid-column:1/-1; margin-top: 1rem;">
                        <button class="domain-btn del" id="purge-data-btn"
                            style="border: 1px solid #ef4444; color: #ef4444; padding: 0.6rem 1rem; border-radius: 8px; justify-content: center; font-weight: 600; font-family: var(--font-sans);">
                            <svg style="margin-right: 6px;" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 6h18"></path>
                                <path d="M19 6l-2 14H7L5 6"></path>
                                <path d="M10 11v6"></path>
                                <path d="M14 11v6"></path>
                                <path d="M9 6V4h6v2"></path>
                            </svg>
                            Purge All Data
                        </button>
                    </div>
                </div>
            </div>

            <div class="settings-card">
                <div class="settings-card-title">Whitelisted Domains</div>
                <div class="domains-list" id="domains-list">
                    <% if (whitelistedDomains && whitelistedDomains.length> 0) { %>
                        <% whitelistedDomains.forEach((d, i)=> { %>
                            <div class="domain-row" data-idx="<%= i %>">
                                <span>
                                    <%= d %>
                                </span>
                                <button class="domain-btn" title="Edit" onclick="editDomain(this)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                </button>
                                <button class="domain-btn del" title="Remove" onclick="removeDomain(this)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14H6L5 6"></path>
                                        <path d="M10 11v6"></path>
                                        <path d="M14 11v6"></path>
                                        <path d="M9 6V4h6v2"></path>
                                    </svg>
                                </button>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="empty-domains" id="empty-msg">No whitelisted domains yet.</div>
                                    <% } %>
                </div>
                <div class="domain-add-row">
                    <input class="domain-input" id="domain-input" type="text" placeholder="example.com"
                        autocomplete="off">
                    <button class="domain-add-btn" id="domain-add-btn">Add</button>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Variables
        const siteSelectorBtn = document.getElementById("site-selector-btn")
        const siteDropdown = document.getElementById("site-dropdown")

        // Functions
        const getDomains = () => {
            return [...document.querySelectorAll("#domains-list .domain-row")].map(r => r.querySelector("span").textContent.trim())
        }

        document.getElementById('purge-data-btn').addEventListener('click', async () => {
            if (confirm("Are you sure you want to delete all analytics data? This action cannot be undone.")) {
                try {
                    const res = await fetch("/api/settings/purge-data", { method: "POST" })
                    const json = await res.json()

                    if (json.ok) {
                        alert("Data purged successfully.")
                        window.location.reload()
                    }
                } catch { }
            }
        })

        const syncEmpty = () => {
            const list = document.getElementById("domains-list")
            let empty = list.querySelector(".empty-domains")

            if (!list.querySelector(".domain-row")) {
                if (!empty) {
                    empty = document.createElement("div")
                    empty.className = "empty-domains"
                    empty.textContent = "No whitelisted domains yet."
                    list.appendChild(empty)
                }
            } else if (empty) empty.remove()
        }

        const saveDomains = async (domains) => {
            await fetch("/api/settings/whitelisted-domains", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ domains })
            })
        }

        const addDomainRow = (domain) => {
            const list = document.getElementById("domains-list")
            const row = document.createElement("div")

            row.className = "domain-row"
            row.innerHTML = `<span>${domain}</span>
                <button class="domain-btn" title="Edit" onclick="editDomain(this)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg></button>
                <button class="domain-btn del" title="Remove" onclick="removeDomain(this)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14H6L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4h6v2"></path></svg></button>`

            list.appendChild(row)
            syncEmpty()
        }

        const removeDomain = (btn) => {
            const row = btn.closest(".domain-row")
            row.remove()
            syncEmpty()
            saveDomains(getDomains())
        }

        const editDomain = (btn) => {
            const row = btn.closest(".domain-row")
            const span = row.querySelector("span")
            const current = span.textContent.trim()

            const inp = document.createElement("input")
            inp.className = "domain-edit-input"
            inp.value = current

            span.replaceWith(inp)
            inp.focus()
            btn.style.display = "none"

            const save = async () => {
                const val = inp.value.trim().toLowerCase().replace(/^https?:\/\//, "").replace(/\/.*$/, "")

                const newSpan = document.createElement("span")
                newSpan.textContent = val || current

                inp.replaceWith(newSpan)
                btn.style.display = ""

                await saveDomains(getDomains())
            }

            inp.addEventListener("blur", save)

            inp.addEventListener("keydown", e => {
                if (e.key === "Enter") inp.blur()
                if (e.key === "Escape") {
                    inp.value = current
                    inp.blur()
                }
            })
        }

        const setDomain = (domain) => {
            document.getElementById("site-selector-label").textContent = domain
            siteDropdown.classList.remove("open")
        }

        // Core
        siteSelectorBtn.addEventListener("click", e => {
            e.stopPropagation()
            siteDropdown.classList.toggle("open")
        })

        const profileWrap = document.getElementById("profile-wrap")

        document.getElementById("profile-btn").addEventListener("click", e => {
            e.stopPropagation()
            profileWrap.classList.toggle("open")
            siteDropdown.classList.remove("open")
        })

        document.addEventListener("click", e => {
            if (!siteDropdown.contains(e.target) && !siteSelectorBtn.contains(e.target)) siteDropdown.classList.remove("open")
            if (!profileWrap.contains(e.target)) profileWrap.classList.remove("open")
        })

        document.getElementById("logout-btn").addEventListener("click", () => {
            window.location.href = "/api/logout"
        })

        document.getElementById("domain-add-btn").addEventListener("click", async () => {
            const input = document.getElementById("domain-input")
            const val = input.value.trim().toLowerCase().replace(/^https?:\/\//, "").replace(/\/.*$/, "")

            if (!val) return

            const existing = getDomains()

            if (existing.includes(val)) {
                input.value = ""
                return
            }

            addDomainRow(val)
            input.value = ""

            await saveDomains([...existing, val])
        })

        document.getElementById("domain-input").addEventListener("keydown", e => {
            if (e.key === "Enter") document.getElementById("domain-add-btn").click()
        })
    </script>
</body>

</html>