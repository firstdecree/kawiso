<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kawiso</title>
    <link rel="canonical" href="https://kawiso.vercel.app/">
    <meta property="og:url" content="https://kawiso.vercel.app/">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Kawiso">
    <meta property="og:title" content="Kawiso">
    <meta property="og:description"
        content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
    <meta name="twitter:description"
        content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
    <meta name="theme-color" content="#FFFFFF">
  <link rel="icon" href="/assets/img/favicon.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --bg: #000;
      --sidebar-bg: #000;
      --surface: #0f0f0f;
      --surface-2: #161616;
      --surface-hover: #1c1c1c;
      --border: #222;
      --border-light: #2a2a2a;
      --text-primary: #f5f5f5;
      --text-secondary: #a3a3a3;
      --text-muted: #5a5a5a;
      --accent: #7c3aed;
      --accent-2: #06b6d4;
      --font-sans: 'Inter', system-ui, sans-serif;
      --font-display: 'Outfit', system-ui, sans-serif;
      --sidebar-width: 260px
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: var(--font-sans);
      display: flex;
      height: 100vh;
      overflow: hidden;
      -webkit-font-smoothing: antialiased
    }

    ::-webkit-scrollbar {
      width: 6px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border-light);
      border-radius: 99px
    }

    .sidebar {
      width: var(--sidebar-width);
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 1.25rem;
      flex-shrink: 0;
      overflow-y: auto
    }

    .sidebar-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 2rem;
      padding: 0 0.5rem
    }

    .sidebar-logo {
      width: 26px;
      height: 26px;
      object-fit: contain
    }

    .sidebar-brand {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: -0.02em
    }

    .site-selector {
      margin-bottom: 2rem;
      position: relative
    }

    .site-selector-btn {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.7rem 1rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: border-color 0.2s
    }

    .site-selector-btn:hover {
      border-color: var(--text-secondary)
    }

    .site-selector-btn svg {
      width: 15px;
      height: 15px;
      color: var(--text-muted)
    }

    .site-dropdown {
      position: absolute;
      top: 100%;
      left: 0.75rem;
      right: 0.75rem;
      margin-top: 4px;
      background: var(--surface-2);
      border: 1px solid var(--border-light);
      border-radius: 8px;
      padding: 0.5rem;
      z-index: 9999;
      display: none;
      box-shadow: 0 10px 25px rgba(0, 0, 0, .5)
    }

    .site-dropdown.open {
      display: block
    }

    .site-dropdown-item {
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      font-size: 0.85rem;
      cursor: pointer;
      transition: background 0.2s;
      color: var(--text-primary)
    }

    .site-dropdown-item:hover {
      background: var(--surface-hover)
    }

    .nav-section {
      margin-bottom: 1.5rem
    }

    .nav-section-title {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      font-weight: 600;
      margin-bottom: 0.4rem;
      padding: 0 0.75rem
    }

    .nav-list {
      list-style: none
    }

    .nav-item {
      margin-bottom: 2px
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0.55rem 0.75rem;
      color: var(--text-secondary);
      text-decoration: none;
      border-radius: 6px;
      font-size: 0.875rem;
      font-weight: 500;
      transition: all 0.15s ease
    }

    .nav-link svg {
      width: 16px;
      height: 16px;
      stroke-width: 2;
      flex-shrink: 0
    }

    .nav-link:hover {
      background: var(--surface-hover);
      color: var(--text-primary)
    }

    .nav-link.active {
      background: var(--surface-2);
      color: var(--text-primary);
      border: 1px solid var(--border)
    }

    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      overflow-y: auto
    }

    .topbar {
      height: 58px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 2rem;
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 1000;
      gap: 1rem;
      flex-shrink: 0
    }

    .topbar-title {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.1rem;
      flex: 1
    }

    .topbar-controls {
      display: flex;
      align-items: center;
      gap: 0.75rem
    }

    .topbar-divider {
      width: 1px;
      height: 20px;
      background: var(--border)
    }

    .profile-wrap {
      position: relative
    }

    .profile-btn {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.3rem 0.6rem 0.3rem 0.4rem;
      cursor: pointer;
      transition: all 0.15s;
      color: var(--text-primary)
    }

    .profile-btn:hover {
      background: var(--surface-hover);
      border-color: var(--border-light)
    }

    .profile-avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
      overflow: hidden
    }

    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover
    }

    .profile-username {
      font-size: 0.85rem;
      font-weight: 500
    }

    .profile-caret {
      width: 14px;
      height: 14px;
      color: var(--text-muted);
      transition: transform 0.2s
    }

    .profile-wrap.open .profile-caret {
      transform: rotate(180deg)
    }

    .profile-dropdown {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      min-width: 180px;
      padding: 0.5rem;
      z-index: 9999;
      box-shadow: 0 8px 24px rgba(0, 0, 0, .6);
      display: none;
      flex-direction: column
    }

    .profile-wrap.open .profile-dropdown {
      display: flex
    }

    .profile-dropdown-header {
      padding: 0.5rem 0.75rem 0.75rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0.4rem
    }

    .profile-dropdown-name {
      font-size: 0.875rem;
      font-weight: 600
    }

    .profile-dropdown-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 2px
    }

    .profile-dropdown-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      font-size: 0.855rem;
      font-weight: 500;
      color: var(--text-secondary);
      text-decoration: none;
      cursor: pointer;
      background: transparent;
      border: none;
      font-family: var(--font-sans);
      width: 100%;
      text-align: left;
      transition: all 0.15s
    }

    .profile-dropdown-item svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0
    }

    .profile-dropdown-item:hover {
      background: var(--surface-hover);
      color: var(--text-primary)
    }

    .profile-dropdown-item.danger {
      color: #ef4444
    }

    .profile-dropdown-item.danger:hover {
      background: rgba(239, 68, 68, .1);
      color: #ef4444
    }

    .pages-body {
      flex: 1;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      width: 100%
    }

    .topbar-range {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .range-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-secondary);
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap
    }

    .range-btn:hover {
      border-color: var(--text-secondary);
      color: var(--text-primary)
    }

    .range-btn.active {
      background: var(--surface-2);
      border-color: var(--border-light);
      color: var(--text-primary)
    }

    .custom-range-wrap {
      position: relative
    }

    .custom-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      display: none;
      flex-direction: column;
      gap: 0.75rem;
      z-index: 9999;
      min-width: 280px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6)
    }

    .custom-popover.open {
      display: flex
    }

    .custom-popover-title {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--text-muted)
    }

    .custom-popover-row {
      display: flex;
      gap: 0.75rem;
      align-items: flex-end
    }

    .custom-popover-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1
    }

    .custom-popover-field label {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-muted)
    }

    .custom-popover-field input[type="date"] {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 0.8rem;
      padding: 0.4rem 0.6rem;
      outline: none;
      transition: border-color 0.15s;
      width: 100%;
      color-scheme: dark
    }

    .custom-popover-field input[type="date"]:focus {
      border-color: var(--accent)
    }

    .custom-apply-btn {
      background: var(--text-primary);
      color: #000;
      border: none;
      border-radius: 6px;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.45rem 0.9rem;
      cursor: pointer;
      transition: opacity 0.15s;
      white-space: nowrap;
      align-self: flex-end
    }

    .custom-apply-btn:hover {
      opacity: 0.85
    }



    .pages-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-bottom: 80px;
    }

    .page-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      display: grid;
      grid-template-columns: 1fr 180px 110px;
      gap: 16px;
      align-items: center;
      padding: 1.25rem 1.5rem;
      transition: border-color 0.15s
    }

    .page-row:hover {
      border-color: var(--border-light);
    }

    .page-left {
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 0
    }

    .page-path {
      font-family: 'Monaco', monospace;
      font-size: 0.82rem;
      color: white;
      font-weight: 500;
      word-break: break-all
    }

    .page-visits {
      font-size: 0.82rem;
      color: var(--text-secondary)
    }

    .page-chart {
      position: relative;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center
    }

    .page-chart svg {
      width: 100%;
      height: 100%
    }

    .page-growth {
      display: flex;
      flex-direction: column;
      gap: 2px;
      align-items: flex-end
    }

    .growth-value {
      font-weight: 600;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 3px
    }

    .growth-value.up {
      color: #22c55e
    }

    .growth-value.down {
      color: #ef4444
    }

    .growth-label {
      font-size: 0.68rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em
    }

    .pagination {
      position: fixed;
      bottom: 0;
      left: var(--sidebar-width);
      right: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 2rem;
      background: var(--bg);
      border-top: 1px solid var(--border);
      gap: 1rem;
      z-index: 100;
    }

    .pagination-info {
      font-size: 0.8rem;
      color: var(--text-muted)
    }

    .pagination-btns {
      display: flex;
      gap: 0.4rem
    }

    .page-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-secondary);
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 500;
      padding: 0.35rem 0.75rem;
      cursor: pointer;
      transition: all 0.15s
    }

    .page-btn:hover:not(:disabled) {
      border-color: var(--text-secondary);
      color: var(--text-primary)
    }

    .page-btn:disabled {
      opacity: 0.35;
      cursor: not-allowed
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 2rem;
      gap: 0.5rem;
      text-align: center;
      color: var(--text-secondary)
    }

    .empty-state-icon {
      font-size: 2.5rem;
      opacity: .5;
      margin-bottom: 0.5rem
    }

    .empty-state-title {
      font-weight: 600;
      color: var(--text-primary)
    }

    .empty-state-text {
      font-size: 0.85rem;
      color: var(--text-secondary)
    }
  </style>
</head>

<body>
  <aside class="sidebar">
    <div class="sidebar-header">
      <img src="/assets/img/logo.png" alt="Kawiso" class="sidebar-logo"
        onerror="this.src='data:image/svg+xml;base64,'">
      <span class="sidebar-brand">Kawiso</span>
    </div>
    <div class="site-selector">
      <button class="site-selector-btn" id="site-selector-btn">
        <span id="site-selector-label">
          <%= activeDomain || 'All Domains' %>
        </span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="site-dropdown" id="site-dropdown">
        <% if (domains && domains.length> 0) { %>
          <% domains.forEach(d=> { %>
            <div class="site-dropdown-item" onclick="setDomain('<%= d %>')">
              <%= d %>
            </div>
            <% }) %>
              <% } else { %>
                <div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No domains yet</div>
                <% } %>
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-section-title">Account</div>
      <ul class="nav-list">
        <li class="nav-item">
          <a href="/account-settings" class="nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            Account Settings
          </a>
        </li>
      </ul>
    </div>
    <div class="nav-section">
      <div class="nav-section-title">Web Analytics</div>
      <ul class="nav-list">
        <li class="nav-item">
          <a href="/dashboard" class="nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="21" x2="9" y2="9"></line>
            </svg>
            Main
          </a>
        </li>
        <li class="nav-item">
          <a href="/map" class="nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon>
              <line x1="9" y1="3" x2="9" y2="21"></line>
              <line x1="15" y1="3" x2="15" y2="21"></line>
            </svg>
            Map
          </a>
        </li>
        <li class="nav-item">
          <a href="/pages" class="nav-link active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            Pages
          </a>
        </li>
      </ul>
    </div>
  </aside>

  <main class="main-content">
    <header class="topbar">
      <h1 class="topbar-title">Pages Analytics</h1>
      <div class="topbar-controls">
        <div class="topbar-range">
          <button class="range-btn" id="btn-7d">7 Days</button>
          <button class="range-btn active" id="btn-1m">1 Month</button>
          <button class="range-btn" id="btn-1y">1 Year</button>
          <div class="custom-range-wrap">
            <button class="range-btn" id="btn-custom">
              <svg style="width:11px;height:11px;display:inline;margin-right:4px;vertical-align:-1px;"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              Custom
            </button>
            <div class="custom-popover" id="custom-popover">
              <div class="custom-popover-title">Custom Date Range</div>
              <div class="custom-popover-row">
                <div class="custom-popover-field">
                  <label for="date-start">Start</label>
                  <input type="date" id="date-start">
                </div>
                <div class="custom-popover-field">
                  <label for="date-end">End</label>
                  <input type="date" id="date-end">
                </div>
                <button class="custom-apply-btn" id="custom-apply">Apply</button>
              </div>
            </div>
          </div>

        </div>
        <div class="topbar-divider"></div>
        <div class="profile-wrap" id="profile-wrap">
          <button class="profile-btn" id="profile-btn">
            <div class="profile-avatar">
              <img src="/assets/img/profile.png" alt="Profile Picture">
            </div>
            <span class="profile-username">
              <%= user.username.toUpperCase() %>
            </span>
            <svg class="profile-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="profile-dropdown">
            <div class="profile-dropdown-header">
              <div class="profile-dropdown-name">
                Plan
              </div>
              <div class="profile-dropdown-sub">
                <%= userDoc.plan.replace(/^./, (c)=>c.toUpperCase()) %>
              </div>
            </div>
            <a href="/account-settings" class="profile-dropdown-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path
                  d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z">
                </path>
              </svg>
              Account Settings
            </a>
            <button class="profile-dropdown-item danger" id="logout-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
              </svg>
              Logout
            </button>
          </div>
        </div>
      </div>
    </header>

    <div class="pages-body">
      <div class="pages-list" id="pagesList">
        <div class="empty-state">
          <div class="empty-state-icon">📄</div>
          <div class="empty-state-title">Loading pages data...</div>
          <div class="empty-state-text">Please wait while we fetch your analytics</div>
        </div>
      </div>
    </div>
    <div class="pagination" id="pagination" style="display:none;">
      <span class="pagination-info" id="pagination-info"></span>
      <div class="pagination-btns">
        <button class="page-btn" id="prev-btn" disabled>← Prev</button>
        <button class="page-btn" id="next-btn" disabled>Next →</button>
      </div>
    </div>
  </main>

  <script>
    const PAGE_SIZE = 10;
    let allPages = [];
    let currentPage = 1;
    let currentRange = '1m';
    let currentStart = null;
    let currentEnd = null;
    let currentDomain = '<%= activeDomain || "" %>';

    const siteSelectorBtn = document.getElementById('site-selector-btn');
    const siteDropdown = document.getElementById('site-dropdown');
    siteSelectorBtn.addEventListener('click', e => { e.stopPropagation(); siteDropdown.classList.toggle('open'); if (typeof customPopover !== 'undefined' && customPopover) customPopover.classList.remove('open'); });

    function setDomain(domain) {
      document.getElementById('site-selector-label').textContent = domain;
      siteDropdown.classList.remove('open');
      currentDomain = domain;
      currentPage = 1;
      fetchPages();
    }

    const profileWrap = document.getElementById('profile-wrap');
    document.getElementById('profile-btn').addEventListener('click', e => {
      e.stopPropagation();
      profileWrap.classList.toggle('open');
      siteDropdown.classList.remove('open');
      if (typeof customPopover !== 'undefined' && customPopover) customPopover.classList.remove('open');
    });
    document.addEventListener('click', e => {
      if (!siteDropdown.contains(e.target) && !siteSelectorBtn.contains(e.target)) siteDropdown.classList.remove('open');
      if (!profileWrap.contains(e.target)) profileWrap.classList.remove('open');
      if (typeof customPopover !== 'undefined' && customPopover && !customPopover.contains(e.target) && e.target !== customBtn && (typeof customBtn !== 'undefined' && !customBtn.contains(e.target))) customPopover.classList.remove('open');
    });
    document.getElementById('logout-btn').addEventListener('click', () => { window.location.href = '/api/logout'; });

    function setActiveRange(btn, range) {
      document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (typeof customPopover !== 'undefined' && customPopover) customPopover.classList.remove('open');
      currentRange = range;
      currentStart = null;
      currentEnd = null;
      currentPage = 1;
      fetchPages();
    }

    document.getElementById('btn-7d').addEventListener('click', function () { setActiveRange(this, '7d'); });
    document.getElementById('btn-1m').addEventListener('click', function () { setActiveRange(this, '1m'); });
    document.getElementById('btn-1y').addEventListener('click', function () { setActiveRange(this, '1y'); });

    const customBtn = document.getElementById('btn-custom');
    const customPopover = document.getElementById('custom-popover');

    customBtn.addEventListener('click', e => {
      e.stopPropagation();
      document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
      customBtn.classList.add('active');
      customPopover.classList.toggle('open');
    });

    document.getElementById('custom-apply').addEventListener('click', () => {
      const s = document.getElementById('date-start').value;
      const e = document.getElementById('date-end').value;
      if (!s || !e) return;
      const fmtD = d => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: '2-digit' });
      customBtn.innerHTML = `<svg style="width:11px;height:11px;display:inline;margin-right:4px;vertical-align:-1px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> ${fmtD(s)} – ${fmtD(e)}`;
      customPopover.classList.remove('open');
      currentRange = 'custom';
      currentStart = s;
      currentEnd = e;
      currentPage = 1;
      fetchPages();
    });



    function createSparkline(data) {
      const w = 180, h = 30, p = 3;
      const cw = w - p * 2, ch = h - p * 2;
      const min = Math.min(...data), max = Math.max(...data);
      const range = max - min || 1;
      const pts = data.map((v, i) => `${p + (i / (data.length - 1)) * cw},${p + ch - ((v - min) / range) * ch}`).join(' ');
      return `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><polyline points="${pts}" fill="none" stroke="#7c3aed" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    }

    function escapeHtml(t) {
      return t.replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[m]));
    }

    function renderPage() {
      const list = document.getElementById('pagesList');
      const pagination = document.getElementById('pagination');
      if (!allPages.length) {
        list.innerHTML = `<div class="empty-state"><div class="empty-state-icon">📄</div><div class="empty-state-title">No pages data available</div><div class="empty-state-text">Pages will appear here once you have analytics data</div></div>`;
        pagination.style.display = 'none';
        return;
      }
      const totalPages = Math.ceil(allPages.length / PAGE_SIZE);
      const start = (currentPage - 1) * PAGE_SIZE;
      const slice = allPages.slice(start, start + PAGE_SIZE);
      list.innerHTML = '';
      slice.forEach(page => {
        const isUp = page.growth === "New" || page.growth >= 0;
        const growthText = page.growth === "New" ? "New" : `${isUp ? '↑' : '↓'} ${Math.abs(page.growth)}%`;
        const row = document.createElement('div');
        row.className = 'page-row';
        row.innerHTML = `<div class="page-left"><div class="page-path">${escapeHtml(page.path)}</div><div class="page-visits">${page.visits.toLocaleString()} visits</div></div><div class="page-chart">${createSparkline(page.sparkline)}</div><div class="page-growth"><div class="growth-value ${isUp ? 'up' : 'down'}">${growthText}</div><div class="growth-label">Growth</div></div>`;
        list.appendChild(row);
      });
      pagination.style.display = 'flex';
      document.getElementById('pagination-info').textContent = `${start + 1}–${Math.min(start + PAGE_SIZE, allPages.length)} of ${allPages.length}`;
      document.getElementById('prev-btn').disabled = currentPage === 1;
      document.getElementById('next-btn').disabled = currentPage === totalPages;
    }

    document.getElementById('prev-btn').addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
    document.getElementById('next-btn').addEventListener('click', () => { if (currentPage < Math.ceil(allPages.length / PAGE_SIZE)) { currentPage++; renderPage(); } });

    async function fetchPages() {
      document.getElementById('pagesList').innerHTML = `<div class="empty-state"><div class="empty-state-icon">📄</div><div class="empty-state-title">Loading...</div><div class="empty-state-text">Fetching analytics data</div></div>`;
      document.getElementById('pagination').style.display = 'none';
      try {
        let url = `/api/pages?range=${currentRange}`;
        if (currentRange === 'custom' && currentStart && currentEnd) {
          url += `&start=${currentStart}&end=${currentEnd}`;
        }
        if (currentDomain) {
          url += `&domain=${encodeURIComponent(currentDomain)}`;
        }
        const res = await fetch(url);
        if (!res.ok) throw new Error();
        const result = await res.json();
        allPages = (result.ok && result.pages) ? result.pages : [];
        currentPage = 1;
        renderPage();
      } catch {
        allPages = [];
        renderPage();
      }
    }

    fetchPages();
  </script>
</body>

</html>