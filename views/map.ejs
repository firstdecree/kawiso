<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kawiso</title>
<link rel="canonical" href="https://kawiso.vercel.app/">
<meta property="og:url" content="https://kawiso.vercel.app/">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Kawiso">
<meta property="og:title" content="Kawiso">
<meta property="og:description"
    content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
<meta name="twitter:description"
    content="Powerful, lightweight and user-friendly privacy-focused analytics platform. Cookieless, open-source and fully compliant with the First Decree.">
<meta name="theme-color" content="#FFFFFF">
<link rel="icon" href="/assets/img/favicon.png" type="image/png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{--bg:#000;--sidebar-bg:#000;--surface:#0f0f0f;--surface-2:#161616;--surface-hover:#1c1c1c;--border:#222;--border-light:#2a2a2a;--text-primary:#f5f5f5;--text-secondary:#a3a3a3;--text-muted:#5a5a5a;--accent:#7c3aed;--accent-2:#06b6d4;--font-sans:'Inter',system-ui,sans-serif;--font-display:'Outfit',system-ui,sans-serif;--sidebar-width:260px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text-primary);font-family:var(--font-sans);display:flex;height:100vh;overflow:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border-light);border-radius:99px}
.sidebar{width:var(--sidebar-width);background:var(--sidebar-bg);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:1.25rem;flex-shrink:0;overflow-y:auto}
.sidebar-header{display:flex;align-items:center;gap:10px;margin-bottom:2rem;padding:0 0.5rem}
.sidebar-logo{width:26px;height:26px;object-fit:contain}
.sidebar-brand{font-family:var(--font-display);font-size:1.2rem;font-weight:700;letter-spacing:-0.02em}
.site-selector{margin-bottom:2rem;position:relative}
.site-selector-btn{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:0.7rem 1rem;color:var(--text-primary);display:flex;align-items:center;justify-content:space-between;font-family:var(--font-sans);font-size:0.875rem;font-weight:500;cursor:pointer;transition:border-color 0.2s}
.site-selector-btn:hover{border-color:var(--text-secondary)}
.site-selector-btn svg{width:15px;height:15px;color:var(--text-muted)}
.site-dropdown{position:absolute;top:100%;left:0.75rem;right:0.75rem;margin-top:4px;background:var(--surface-2);border:1px solid var(--border-light);border-radius:8px;padding:0.5rem;z-index:9999;display:none;box-shadow:0 10px 25px rgba(0,0,0,0.5)}
.site-dropdown.open{display:block}
.site-dropdown-item{padding:0.5rem 0.75rem;border-radius:6px;font-size:0.85rem;cursor:pointer;transition:background 0.2s;color:var(--text-primary)}
.site-dropdown-item:hover{background:var(--surface-hover)}
.nav-section{margin-bottom:1.5rem}
.nav-section-title{font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);font-weight:600;margin-bottom:0.4rem;padding:0 0.75rem}
.nav-list{list-style:none}
.nav-item{margin-bottom:2px}
.nav-link{display:flex;align-items:center;gap:10px;padding:0.55rem 0.75rem;color:var(--text-secondary);text-decoration:none;border-radius:6px;font-size:0.875rem;font-weight:500;transition:all 0.15s ease}
.nav-link svg{width:16px;height:16px;stroke-width:2;flex-shrink:0}
.nav-link:hover{background:var(--surface-hover);color:var(--text-primary)}
.nav-link.active{background:var(--surface-2);color:var(--text-primary);border:1px solid var(--border)}
.main-content{flex:1;display:flex;flex-direction:column;min-width:0}
.topbar{height:58px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 2rem;background:var(--bg);position:sticky;top:0;z-index:1000;gap:1rem;flex-shrink:0}
.topbar-title{font-family:var(--font-display);font-weight:600;font-size:1.1rem;flex:1}
.topbar-controls{display:flex;align-items:center;gap:0.75rem}
.topbar-range{display:flex;gap:4px;align-items:center}
.range-btn{background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--text-secondary);font-family:var(--font-sans);font-size:0.8rem;font-weight:500;padding:0.3rem 0.7rem;cursor:pointer;transition:all 0.15s;white-space:nowrap}
.range-btn:hover{border-color:var(--text-secondary);color:var(--text-primary)}
.range-btn.active{background:var(--surface-2);border-color:var(--border-light);color:var(--text-primary)}
.custom-range-wrap{position:relative}
.custom-popover{position:absolute;top:calc(100% + 10px);right:0;background:var(--surface);border:1px solid var(--border-light);border-radius:10px;padding:1rem 1.25rem;display:none;flex-direction:column;gap:0.75rem;z-index:9999;min-width:280px;box-shadow:0 8px 24px rgba(0,0,0,0.6)}
.custom-popover.open{display:flex}
.custom-popover-title{font-size:0.78rem;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:var(--text-muted)}
.custom-popover-row{display:flex;gap:0.75rem;align-items:flex-end}
.custom-popover-field{display:flex;flex-direction:column;gap:4px;flex:1}
.custom-popover-field label{font-size:0.75rem;font-weight:500;color:var(--text-muted)}
.custom-popover-field input[type="date"]{background:var(--surface-2);border:1px solid var(--border);border-radius:6px;color:var(--text-primary);font-family:var(--font-sans);font-size:0.8rem;padding:0.4rem 0.6rem;outline:none;transition:border-color 0.15s;width:100%;color-scheme:dark}
.custom-popover-field input[type="date"]:focus{border-color:var(--accent)}
.custom-apply-btn{background:var(--text-primary);color:#000;border:none;border-radius:6px;font-family:var(--font-sans);font-size:0.8rem;font-weight:600;padding:0.45rem 0.9rem;cursor:pointer;transition:opacity 0.15s;white-space:nowrap;align-self:flex-end}
.custom-apply-btn:hover{opacity:0.85}
.topbar-divider{width:1px;height:20px;background:var(--border)}
.profile-wrap{position:relative}
.profile-btn{display:flex;align-items:center;gap:0.6rem;background:transparent;border:1px solid var(--border);border-radius:8px;padding:0.3rem 0.6rem 0.3rem 0.4rem;cursor:pointer;transition:all 0.15s;color:var(--text-primary)}
.profile-btn:hover{background:var(--surface-hover);border-color:var(--border-light)}
.profile-avatar{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.profile-avatar img{width:100%;height:100%;object-fit:cover}
.profile-username{font-size:0.85rem;font-weight:500}
.profile-caret{width:14px;height:14px;color:var(--text-muted);transition:transform 0.2s}
.profile-wrap.open .profile-caret{transform:rotate(180deg)}
.profile-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:var(--surface);border:1px solid var(--border-light);border-radius:10px;min-width:180px;padding:0.5rem;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,0.6);display:none;flex-direction:column}
.profile-wrap.open .profile-dropdown{display:flex}
.profile-dropdown-header{padding:0.5rem 0.75rem 0.75rem;border-bottom:1px solid var(--border);margin-bottom:0.4rem}
.profile-dropdown-name{font-size:0.875rem;font-weight:600}
.profile-dropdown-sub{font-size:0.75rem;color:var(--text-muted);margin-top:2px}
.profile-dropdown-item{display:flex;align-items:center;gap:8px;padding:0.5rem 0.75rem;border-radius:6px;font-size:0.855rem;font-weight:500;color:var(--text-secondary);text-decoration:none;cursor:pointer;background:transparent;border:none;font-family:var(--font-sans);width:100%;text-align:left;transition:all 0.15s}
.profile-dropdown-item svg{width:15px;height:15px;flex-shrink:0}
.profile-dropdown-item:hover{background:var(--surface-hover);color:var(--text-primary)}
.profile-dropdown-item.danger{color:#ef4444}
.profile-dropdown-item.danger:hover{background:rgba(239,68,68,0.1);color:#ef4444}
#map{flex:1;background:#0a0a0a}
.leaflet-container{background:#0a0a0a !important}
.leaflet-control-zoom a{background:var(--surface-2) !important;color:var(--text-primary) !important;border-color:var(--border) !important}
.leaflet-control-zoom a:hover{background:var(--surface-hover) !important}
.leaflet-control-attribution{background:rgba(0,0,0,0.7) !important;color:var(--text-muted) !important;font-size:9px !important}
.leaflet-control-attribution a{color:var(--text-muted) !important}
.map-tooltip{background:var(--surface-2);border:1px solid var(--border-light);color:var(--text-primary);font-family:var(--font-sans);font-size:0.8rem;border-radius:8px;padding:8px 12px;box-shadow:0 4px 20px rgba(0,0,0,0.7);pointer-events:none;white-space:nowrap}
.map-tooltip strong{display:block;font-weight:600;margin-bottom:2px}
.map-tooltip span{color:var(--text-secondary);font-size:0.75rem}
.legend{position:absolute;bottom:2rem;right:1rem;z-index:500;background:var(--surface-2);border:1px solid var(--border-light);border-radius:10px;padding:1rem 1.25rem;min-width:160px}
.legend-title{font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:0.75rem}
.legend-scale{height:10px;border-radius:99px;background:linear-gradient(90deg,#1a0a3e,#7c3aed);margin-bottom:0.5rem}
.legend-labels{display:flex;justify-content:space-between;font-size:0.72rem;color:var(--text-muted)}
.no-data-overlay{display:none;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:0.75rem;background:rgba(0,0,0,0.85);z-index:600;text-align:center}
.no-data-overlay.show{display:flex}
.no-data-icon{font-size:2.5rem}
.no-data-title{font-family:var(--font-display);font-size:1.2rem;font-weight:600}
.no-data-sub{font-size:0.875rem;color:var(--text-secondary);max-width:360px;line-height:1.6}
</style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-header">
        <img src="/assets/img/logo.png" alt="Kawiso" class="sidebar-logo" onerror="this.src='data:image/svg+xml;base64,'">
        <span class="sidebar-brand">Kawiso</span>
    </div>
    <div class="site-selector">
        <button class="site-selector-btn" id="site-selector-btn">
            <span id="site-selector-label"><%= activeDomain || "No Domain Active" %></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="site-dropdown" id="site-dropdown">
            <% if (domains && domains.length > 0) { %>
                <% domains.forEach(d => { %>
                    <div class="site-dropdown-item" onclick="setDomain('<%= d %>')"><%= d %></div>
                <% }) %>
            <% } else { %>
                <div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No domains yet</div>
            <% } %>
        </div>
    </div>
    <div class="nav-section">
        <div class="nav-section-title">Account</div>
        <ul class="nav-list">
            <li class="nav-item">
                <a href="/account-settings" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    Account Settings
                </a>
            </li>
        </ul>
    </div>
    <div class="nav-section">
        <div class="nav-section-title">Web Analytics</div>
        <ul class="nav-list">
            <li class="nav-item">
                <a href="/dashboard" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                    Main
                </a>
            </li>
            <li class="nav-item">
                <a href="/map" class="nav-link active">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line></svg>
                    Map
                </a>
            </li>
             <li class="nav-item">
                    <a href="/pages" class="nav-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                            stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                        </svg>
                        Pages
                    </a>
                </li>
        </ul>
    </div>
</aside>

<main class="main-content">
    <header class="topbar">
        <h1 class="topbar-title">Visitor Map</h1>
        <div class="topbar-controls">
            <div class="topbar-range">
                <button class="range-btn" id="btn-7d">7 Days</button>
                <button class="range-btn active" id="btn-1m">1 Month</button>
                <button class="range-btn" id="btn-1y">1 Year</button>
                <div class="custom-range-wrap">
                    <button class="range-btn" id="btn-custom">
                        <svg style="width:11px;height:11px;display:inline;margin-right:4px;vertical-align:-1px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Custom
                    </button>
                    <div class="custom-popover" id="custom-popover">
                        <div class="custom-popover-title">Custom Date Range</div>
                        <div class="custom-popover-row">
                            <div class="custom-popover-field">
                                <label for="date-start">Start</label>
                                <input type="date" id="date-start">
                            </div>
                            <div class="custom-popover-field">
                                <label for="date-end">End</label>
                                <input type="date" id="date-end">
                            </div>
                            <button class="custom-apply-btn" id="custom-apply">Apply</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="topbar-divider"></div>
            <div class="profile-wrap" id="profile-wrap">
                <button class="profile-btn" id="profile-btn">
                    <div class="profile-avatar">
                        <img src="/assets/img/profile.png" alt="Profile Picture">
                    </div>
                    <span class="profile-username"><%= user.username.toUpperCase() %></span>
                    <svg class="profile-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div class="profile-dropdown">
                    <div class="profile-dropdown-header">
                        <div class="profile-dropdown-name">Plan</div>
                        <div class="profile-dropdown-sub"><%= userDoc.plan.replace(/^./, (c)=>c.toUpperCase()) %></div>
                    </div>
                    <a href="/account-settings" class="profile-dropdown-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                        Account Settings
                    </a>
                    <button class="profile-dropdown-item danger" id="logout-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                        Logout
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div style="position:relative;flex:1;display:flex;flex-direction:column;">
        <div id="map" style="flex:1;"></div>
        <div class="legend">
            <div class="legend-title">Visits</div>
            <div class="legend-scale"></div>
            <div class="legend-labels"><span>0</span><span id="legend-max">—</span></div>
        </div>
        <div class="no-data-overlay" id="no-data">
            <div class="no-data-icon">📡</div>
            <div class="no-data-title">No visitor data yet</div>
            <p class="no-data-sub">Once visitors arrive from the selected domain and period, they'll appear on the map.</p>
        </div>
    </div>
</main>

<script>
const INITIAL = <%- JSON.stringify(analytics) %>;
let currentFetchParams = { range: '1m', domain: '<%= activeDomain || "" %>' };

const map = L.map('map', {
    center: [20, 0],
    zoom: 2,
    minZoom: 1,
    maxZoom: 6,
    zoomControl: true,
    attributionControl: true
});

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
    subdomains: 'abcd',
    maxZoom: 19
}).addTo(map);

let geojsonLayer = null;
let visitData = {};

function getColor(count, max) {
    if (!count || !max) return '#1e1e2e';
    const t = Math.log(count + 1) / Math.log(max + 1);
    const r = Math.round(26 + t * (124 - 26));
    const g = Math.round(26 + t * (58 - 26));
    const b = Math.round(46 + t * (237 - 46));
    return `rgb(${r},${g},${b})`;
}

function styleFeature(feature) {
    const name = feature.properties.ADMIN || feature.properties.name || '';
    const count = visitData[name.toLowerCase()] || 0;
    const max = visitData.__max__ || 1;
    return {
        fillColor: getColor(count, max),
        fillOpacity: count ? 0.85 : 0.3,
        color: '#111',
        weight: 0.5,
        opacity: 1
    };
}

const tooltip = L.tooltip({ permanent: false, sticky: true, className: 'map-tooltip', offset: [10, 0] });

function onEachFeature(feature, layer) {
    const name = feature.properties.ADMIN || feature.properties.name || 'Unknown';
    layer.on({
        mouseover(e) {
            const count = visitData[name.toLowerCase()] || 0;
            layer.setStyle({ fillOpacity: 1, weight: 1.5, color: '#7c3aed' });
            tooltip.setContent(`<strong>${name}</strong><span>${count.toLocaleString()} visit${count !== 1 ? 's' : ''}</span>`);
            if (!tooltip.isOpen()) map.openTooltip(tooltip, e.latlng);
        },
        mousemove(e) { tooltip.setLatLng(e.latlng); },
        mouseout() {
            geojsonLayer.resetStyle(layer);
            map.closeTooltip(tooltip);
        }
    });
}

function normalizeCountryName(name) {
    const aliases = {
        'united states of america': 'united states',
        'russian federation': 'russia',
        'republic of korea': 'south korea',
        'democratic republic of the congo': 'dr congo',
        "côte d'ivoire": "cote d'ivoire",
        'viet nam': 'vietnam',
        'czech republic': 'czechia',
        'taiwan': 'taiwan',
        'iran (islamic republic of)': 'iran',
        'syrian arab republic': 'syria',
        'lao pdr': 'laos',
        'moldova (republic of)': 'moldova',
        'bolivia (plurinational state of)': 'bolivia',
        'venezuela (bolivarian republic of)': 'venezuela',
        "dem. people's republic of korea": 'north korea',
        'united republic of tanzania': 'tanzania',
        'myanmar': 'myanmar',
        'brunei darussalam': 'brunei'
    };
    const lower = name.toLowerCase();
    return aliases[lower] || lower;
}

function buildVisitData(countries) {
    const d = {};
    if (!countries) return d;
    let max = 0;
    countries.forEach(c => {
        const key = normalizeCountryName(c.name);
        d[key] = c.count;
        if (c.count > max) max = c.count;
    });
    d.__max__ = max;
    return d;
}

function updateMap(countries) {
    visitData = buildVisitData(countries);
    const max = visitData.__max__ || 0;
    document.getElementById('legend-max').textContent = max.toLocaleString();
    document.getElementById('no-data').classList.toggle('show', !max);
    if (geojsonLayer) geojsonLayer.setStyle(styleFeature);
}

fetch('https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson')
    .then(r => r.json())
    .then(geo => {
        geojsonLayer = L.geoJSON(geo, { style: styleFeature, onEachFeature }).addTo(map);
        updateMap(INITIAL ? INITIAL.countries : null);
    })
    .catch(() => {
        fetch('https://cdn.jsdelivr.net/npm/world-atlas@2.0.2/countries-110m.json')
            .then(r => r.json())
            .then(topo => {
                const script = document.createElement('script');
                script.src = 'https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js';
                script.onload = () => {
                    const geo = topojson.feature(topo, topo.objects.countries);
                    geojsonLayer = L.geoJSON(geo, { style: styleFeature, onEachFeature }).addTo(map);
                    updateMap(INITIAL ? INITIAL.countries : null);
                };
                document.head.appendChild(script);
            });
    });

async function fetchAndRender() {
    try {
        const res = await fetch('/api/analytics?' + new URLSearchParams(currentFetchParams));
        const json = await res.json();
        updateMap(json.data ? json.data.countries : null);
    } catch(e) {}
}

setInterval(async () => {
    fetchAndRender();
    try {
        const res = await fetch('/api/domains');
        const json = await res.json();
        if (!json.ok) return;
        const dropdown = document.getElementById('site-dropdown');
        if (!json.domains.length) {
            dropdown.innerHTML = '<div class="site-dropdown-item" style="color:var(--text-muted);cursor:default;">No domains yet</div>';
        } else {
            dropdown.innerHTML = json.domains.map(d => `<div class="site-dropdown-item" onclick="setDomain('${d}')">${d}</div>`).join('');
            const cur = document.getElementById('site-selector-label').textContent.trim();
            if (cur === 'No Domain Active' || !json.domains.includes(cur)) setDomain(json.domains[0]);
        }
    } catch(e) {}
}, 5000);

function setActiveRange(btn, range) {
    document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    customPopover.classList.remove('open');
    currentFetchParams.range = range;
    delete currentFetchParams.start;
    delete currentFetchParams.end;
    fetchAndRender();
}

document.getElementById('btn-7d').addEventListener('click', function(){ setActiveRange(this,'7d'); });
document.getElementById('btn-1m').addEventListener('click', function(){ setActiveRange(this,'1m'); });
document.getElementById('btn-1y').addEventListener('click', function(){ setActiveRange(this,'1y'); });

const customBtn = document.getElementById('btn-custom');
const customPopover = document.getElementById('custom-popover');
customBtn.addEventListener('click', e => {
    e.stopPropagation();
    document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
    customBtn.classList.add('active');
    customPopover.classList.toggle('open');
});
document.getElementById('custom-apply').addEventListener('click', () => {
    const s = document.getElementById('date-start').value;
    const e = document.getElementById('date-end').value;
    if (!s || !e) return;
    const fmtD = d => new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});
    customBtn.textContent = `${fmtD(s)} – ${fmtD(e)}`;
    customPopover.classList.remove('open');
    currentFetchParams.range = 'custom';
    currentFetchParams.start = s;
    currentFetchParams.end = e;
    fetchAndRender();
});

const siteSelectorBtn = document.getElementById('site-selector-btn');
const siteDropdown = document.getElementById('site-dropdown');
siteSelectorBtn.addEventListener('click', e => { e.stopPropagation(); siteDropdown.classList.toggle('open'); customPopover.classList.remove('open'); });

function setDomain(domain) {
    document.getElementById('site-selector-label').textContent = domain;
    currentFetchParams.domain = domain;
    fetchAndRender();
    siteDropdown.classList.remove('open');
}

const profileWrap = document.getElementById('profile-wrap');
document.getElementById('profile-btn').addEventListener('click', e => {
    e.stopPropagation();
    profileWrap.classList.toggle('open');
    customPopover.classList.remove('open');
    siteDropdown.classList.remove('open');
});
document.addEventListener('click', e => {
    if (!siteDropdown.contains(e.target) && !siteSelectorBtn.contains(e.target)) siteDropdown.classList.remove('open');
    if (!customPopover.contains(e.target) && e.target !== customBtn) customPopover.classList.remove('open');
    if (!profileWrap.contains(e.target)) profileWrap.classList.remove('open');
});
document.getElementById('logout-btn').addEventListener('click', () => { window.location.href = '/api/logout'; });
</script>
</body>
</html>